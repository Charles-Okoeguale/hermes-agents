# Copy this file to .env and fill in your real keys. Never commit .env.

# LLM provider key — Hermes reads this when you run `hermes model`.
# Example for Anthropic:
ANTHROPIC_API_KEY=sk-ant-...

# Web search key for the web_search tool (https://tavily.com — free tier available).
TAVILY_API_KEY=tvly-...

# Optional: override the model the agent uses.
# HERMES_MODEL=anthropic/claude-sonnet-4.6
